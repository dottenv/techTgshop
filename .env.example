# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
BOT_WEBHOOK_URL=https://your-domain.com/webhook/bot
BOT_WEBHOOK_PATH=/webhook/bot

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/tech_tgshop
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tech_tgshop
DATABASE_USER=user
DATABASE_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Web Admin Panel Configuration
WEB_SECRET_KEY=your_secret_key_here
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=false

# Webhook Server Configuration
WEBHOOK_SECRET_KEY=your_webhook_secret_here
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# Payment Systems
YOOKASSA_SHOP_ID=your_yookassa_shop_id
YOOKASSA_SECRET_KEY=your_yookassa_secret_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Docker Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tech_tgshop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password

REDIS_HOST=redis
REDIS_PORT=6379
